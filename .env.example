# =============================================================================
# X++ MCP Server — Configuration
# =============================================================================
# Copy this file to .env and fill in the relevant section for your deployment:
#
#   local  → single VM with D365FO; MCP_SERVER_MODE=full (default)
#   hybrid → Azure read-only + local write-only companion
#   azure  → Azure-hosted read-only instance; MCP_SERVER_MODE=read-only
#
# MULTI-INSTANCE SETUP
# If you need to run multiple server instances (each pointing to a different
# D365FO environment) from a single source/dist folder, create a separate .env
# file per instance and point to it via the ENV_FILE environment variable:
#
#   .env.alpha   — Instance 1 config (port 8080, alpha DB/metadata)
#   .env.beta    — Instance 2 config (port 8081, beta  DB/metadata)
#
#   Windows:
#     set ENV_FILE=.env.alpha && node dist/index.js
#     set ENV_FILE=.env.beta  && node dist/index.js
#
#   PowerShell:
#     $env:ENV_FILE='.env.alpha'; node dist/index.js
#
#   Build scripts respect ENV_FILE too:
#     set ENV_FILE=.env.alpha && npm run extract-metadata
#     set ENV_FILE=.env.alpha && npm run build-database
#
# =============================================================================
# GENERAL — required in all modes
# =============================================================================

# Runtime environment
NODE_ENV=development          # development | staging | production
PORT=8080                     # HTTP listen port
LOG_LEVEL=debug               # error | warn | info | debug

# =============================================================================
# MODE: LOCAL  (MCP_SERVER_MODE=full)
# =============================================================================
# Standard single-VM setup. All tools are available.
# ------------------------------------------------------------------
MCP_SERVER_MODE=full          # full (default) | read-only | write-only

# Dev environment detection: auto (default), traditional, ude (Power Platform Tools)
# 'auto' detects UDE when XPP config files exist in %LOCALAPPDATA%\Microsoft\Dynamics365\XPPConfig\
D365FO_DEV_ENVIRONMENT_TYPE=auto
# Legacy name (still honored as a fallback if the prefixed one is unset): DEV_ENVIRONMENT_TYPE=auto

# --- Traditional (AOSService VM) ---

# Root folder of all D365FO packages.
D365FO_PACKAGE_PATH=C:\AOSService\PackagesLocalDirectory

# Comma-separated custom model names (UDE auto-detects these; only needed for traditional)
# Find in VS → Dynamics 365 → Model Management → View models
CUSTOM_MODELS=YourCustomModel1,YourCustomModel2

# --- UDE (Unified Developer Experience / Power Platform Tools) ---

# XPP config name from %LOCALAPPDATA%\Microsoft\Dynamics365\XPPConfig\
# Leave empty to use the newest config automatically.
# Run  npm run select-config  to pick interactively.
# XPP_CONFIG_NAME=contoso-dev-env1___10.0.2428.63

# --- Database & extraction ---

# SQLite database with indexed X++ metadata
DB_PATH=./data/xpp-metadata.db

# Output folder for extracted XML metadata
METADATA_PATH=./extracted-metadata

# Index label files during DB build; disable to speed up build (labels(action="search") won't work)
INCLUDE_LABELS=true

# Languages to index — limiting this significantly reduces DB size
LABEL_LANGUAGES=en-US,cs,sk,de

# Label sort order: "alphabetical" (default) or "append" (new labels added at end of file)
# LABEL_SORT_ORDER=alphabetical

# ISV/extension prefix used to identify custom objects
EXTENSION_PREFIX=ISV_

# Optional suffix appended to new object names (e.g. MyTableZZ with EXTENSION_SUFFIX=ZZ)
# Most projects use only a prefix — leave unset unless your naming convention requires a suffix.
# EXTENSION_SUFFIX=

# Extension naming style — how extension elements/classes are named:
#   prefix     (default): embed the EXTENSION_PREFIX infix, per MS prefix guideline
#                         (e.g. CustTable.CrExtension, CustTableCr_Extension)
#   model-name          : embed the MODEL NAME, matching the Visual Studio default
#                         (e.g. CustTable.ContosoRobotics, CustTable_ContosoRobotics_Extension).
#                         EXTENSION_PREFIX still applies to new objects and extension fields/methods.
# Use model-name when your model name is long/customer-specific but your prefix is a short abbreviation.
# EXTENSION_NAMING_STYLE=prefix

# Extraction scope: all (standard + custom) | standard | custom
# EXTRACT_MODE=all

# Compute usage statistics during build (slow for large databases)
# COMPUTE_STATS=false

# --- Azure Blob Storage — source of the indexed DB ---

# Find connection string in: Azure Portal → Storage Account → Access keys
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net
# BLOB_CONTAINER_NAME=xpp-databases
# BLOB_DATABASE_NAME=xpp-metadata.db

# =============================================================================
# D365FO CONTEXT — passed via .mcp.json env block (NOT .env)
# =============================================================================
# These D365FO_* variables are normally set in .mcp.json inside the server's
# "env" block so VS 2022 passes them to the subprocess. They are listed here
# for reference only — you do NOT need to set them in .env unless running
# the server manually from the command line (npm run dev / node dist/index.js).
#
# D365FO_WORKSPACE_PATH=K:\AOSService\PackagesLocalDirectory\YourPackage\YourModel
# D365FO_PACKAGE_PATH=K:\AOSService\PackagesLocalDirectory   # ← primary env var for packages root
# D365FO_MODEL_NAME=YourModelName
# D365FO_PROJECT_PATH=K:\repos\MySolution\MyProject\MyProject.rnrproj
# D365FO_SOLUTION_PATH=K:\repos\MySolution\MySolution.sln
# D365FO_SOLUTIONS_PATH=K:\repos\MySolution\projects
# D365FO_CUSTOM_PACKAGES_PATH=C:\CustomXppCode                # UDE: ModelStoreFolder
# D365FO_MICROSOFT_PACKAGES_PATH=C:\Users\...\PackagesLocalDirectory  # UDE: FrameworkDirectory
# D365FO_BRIDGE_LOG_FILE=C:\Temp\d365fo-bridge.log
#
# Bridge timeouts (milliseconds). Raise these on large installations or slow VMs
# where metadata-provider init or big searches exceed the defaults.
# BRIDGE_READY_TIMEOUT_MS=30000   # time to wait for the C# bridge to become ready (default 30000)
# BRIDGE_CALL_TIMEOUT_MS=60000    # per-call timeout for a single bridge request (default 60000)
#
# Bridge resilience. READ calls are auto-retried on timeout/pipe error with a
# health-checked restart of the child process in between; WRITE calls are never
# retried (a timed-out write may have already applied — replaying could duplicate it).
# BRIDGE_MAX_RETRIES=2            # max retries for read calls (0 = disabled)
# BRIDGE_HEALTHCHECK_MS=0         # idle ping interval in ms (0 = disabled)
# BRIDGE_MAX_RESTARTS=3           # max child respawns per 60s before giving up

# =============================================================================
# MODE: HYBRID  (local write-only companion for an Azure-hosted read-only instance)
# =============================================================================
# The Azure read-only instance runs entirely in the cloud — configure it via
# Azure App Service settings, not via .env.
# This section covers only the local write-only companion on the Windows VM.
# ------------------------------------------------------------------

# MCP_SERVER_MODE=write-only
# CUSTOM_MODELS=YourCustomModel1,YourCustomModel2
# INCLUDE_LABELS=true
# LABEL_LANGUAGES=en-US,cs,sk,de
# EXTENSION_PREFIX=ISV_
# EXTENSION_SUFFIX=

# =============================================================================
# FORM PATTERN ENFORCEMENT
# =============================================================================
# Structural form-pattern violations (rules FP001-FP005, FP007: unknown pattern,
# missing required container, wrong control order, disallowed child type,
# misapplied sub-pattern) BLOCK form writes in create_d365fo_file and
# modify_d365fo_file(add-control). Recommendations (FP006, FP008-FP010) only warn.
# Enabled by default; set to false to log pattern errors without blocking.
# FORM_PATTERN_ENFORCE=true

# =============================================================================
# GROUNDING TOKENS — HYBRID DEPLOYMENT
# =============================================================================
# By default grounding tokens issued by prepare(mode=change/create) live in the
# issuing process's memory, so GROUNDING_ENFORCE only works on a single
# full-mode server. Set the SAME random secret on BOTH instances of a hybrid
# deployment (Azure read-only + local write-only companion) to switch to
# HMAC-signed portable tokens: the companion can then validate tokens issued
# by the Azure instance and enforcement works end-to-end. Also required when
# the App Service is scaled out to more than one instance.
# GROUNDING_SECRET=<same-long-random-string-on-both-instances>
